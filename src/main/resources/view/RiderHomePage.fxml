<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane style="-fx-background-color: #1a1a1a; -fx-min-width: 900; -fx-min-height: 750;"
            stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.alessandro.caracciolo.catchit.view.controller.RiderGraphicController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2a2a2a; -fx-padding: 15 30;">
            <ImageView fitHeight="66.0" fitWidth="112.0" preserveRatio="true">
               <Image url="@../Logo.png" />
            </ImageView>
            <Label text="Rider" textFill="white">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Menu buttons -->
            <Button fx:id="logoutButton"
                    onAction="#handleLogoutButton"
                    style="-fx-background-color: transparent; -fx-text-fill: #64b5f6;"
                    text="Logout">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor></Button>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox prefHeight="369.0" prefWidth="591.0" spacing="20" style="-fx-padding: 30;">

            <VBox prefHeight="597.0" prefWidth="896.0" spacing="15" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-padding: 20;">
            <Label style="-fx-background-color: #2196f3; -fx-background-radius: 25; -fx-padding: 10 20; -fx-alignment: center;"
                   text="Assigned Orders" textFill="white">
               <font>
                  <Font name="System Bold" size="16" />
               </font>
            </Label>

                <ScrollPane fitToWidth="true" prefHeight="508.0" prefWidth="515.0" style="-fx-background-color: transparent;">
                    <VBox fx:id="ordersContainer" prefHeight="0.0" prefWidth="513.0" spacing="15" style="-fx-background-color: transparent;">

                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
