<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #1a1a1a; -fx-min-width: 900; -fx-min-height: 750;"
            styleClass="style.css"
            stylesheets="@../style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.alessandro.caracciolo.catchit.view.controller.RestaurantGraphicController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2a2a2a; -fx-padding: 15 30;">
            <ImageView fitHeight="66.0" fitWidth="112.0" preserveRatio="true">
               <Image url="@../Logo.png" />
            </ImageView>
            <Label text="Manage orders" textFill="white">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Menu buttons -->
            <Button fx:id="logoutButton"
                    onAction="#handleLogoutButton"
                    style="-fx-background-color: transparent; -fx-text-fill: #64b5f6;"
                    text="Logout">
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor></Button>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox prefHeight="369.0" prefWidth="591.0" spacing="20" style="-fx-padding: 30;">

            <!-- Colonna Sinistra: Pronti per Assegnazione -->
            <VBox prefHeight="597.0" prefWidth="561.0" spacing="15" style="-fx-background-color: #2a2a2a;                   -fx-background-radius: 10; -fx-padding: 20;">
            <Label style="-fx-background-color: #2196f3; -fx-background-radius: 25;                               -fx-padding: 10 20; -fx-alignment: center;" text="Pending orders" textFill="white">
               <font>
                  <Font name="System Bold" size="16" />
               </font>
            </Label>

                <ScrollPane fitToWidth="true" prefHeight="508.0" prefWidth="515.0" style="-fx-background-color: transparent;">
                    <VBox fx:id="ordersContainer" prefHeight="0.0" prefWidth="513.0" spacing="15" style="-fx-background-color: transparent;">

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Colonna Destra: Rider Disponibili -->
            <VBox prefHeight="597.0" prefWidth="272.0" spacing="15" style="-fx-background-color: #2a2a2a;                   -fx-background-radius: 10; -fx-padding: 20;">
                <Label style="-fx-background-color: #2196f3; -fx-background-radius: 25;                               -fx-padding: 10 20; -fx-alignment: center;" text="Available Riders" textFill="white">
                    <font>
                        <Font name="System Bold" size="16" />
                    </font>
                </Label>

                <!-- Rider List -->
                <VBox fx:id="ridersContainer" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10;">
                        <VBox spacing="3">
                            <HBox alignment="CENTER_LEFT" spacing="5" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>


    <!-- Bottom Notification -->
    <bottom>
        <HBox fx:id="notificationBox" alignment="CENTER_LEFT" managed="false" spacing="10" style="-fx-background-color: #1565c0; -fx-padding: 12 30; -fx-background-radius: 5;" visible="false">
            <Label style="-fx-background-color: #0d47a1; -fx-background-radius: 15; -fx-padding: 5 10; -fx-font-weight: bold;" text="✓" textFill="white" />
            <Label fx:id="notificationText" text="Ordine assegnato" textFill="white">
                <font>
                    <Font size="13" />
                </font>
            </Label>
            <padding>
                <Insets bottom="20" left="30" right="30" />
            </padding>
        </HBox>
    </bottom>
</BorderPane>
