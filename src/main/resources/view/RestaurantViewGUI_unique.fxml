<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane style="-fx-background-color: #1a1a1a; -fx-min-width: 900; -fx-min-height: 750;" styleClass="style.css" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alessandro.caracciolo.catchit.view.controller.RestaurantGraphicController">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #2a2a2a; -fx-padding: 15 30;">
            <ImageView fitHeight="66.0" fitWidth="112.0" preserveRatio="true">
            <image>
               <Image url="@../Logo.png" />
            </image></ImageView>
            <Label text="Gestione Consegne" textFill="white">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>

            <Region HBox.hgrow="ALWAYS" />

            <!-- Menu buttons -->
            <Button style="-fx-background-color: transparent; -fx-text-fill: #64b5f6;" text="Logout" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Impostazioni" />
            <Button style="-fx-background-color: transparent; -fx-text-fill: white;" text="Gestione Menu" />
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <HBox prefHeight="369.0" prefWidth="591.0" spacing="20" style="-fx-padding: 30;">

            <!-- Colonna Sinistra: Pronti per Assegnazione -->
            <VBox prefHeight="597.0" prefWidth="561.0" spacing="15" style="-fx-background-color: #2a2a2a;                   -fx-background-radius: 10; -fx-padding: 20;">
            <Label style="-fx-background-color: #2196f3; -fx-background-radius: 25;                               -fx-padding: 10 20; -fx-alignment: center;" text="Ordini in attesa" textFill="white">
               <font>
                  <Font name="System Bold" size="16" />
               </font>
            </Label>

                <ScrollPane fitToWidth="true" prefHeight="508.0" prefWidth="515.0" style="-fx-background-color: transparent;">
                    <VBox fx:id="ordersContainer" prefHeight="0.0" prefWidth="513.0" spacing="15" style="-fx-background-color: transparent;">

                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- Colonna Destra: Rider Disponibili -->
            <VBox prefHeight="597.0" prefWidth="272.0" spacing="15" style="-fx-background-color: #2a2a2a;                   -fx-background-radius: 10; -fx-padding: 20;">
                <Label style="-fx-background-color: #2196f3; -fx-background-radius: 25;                               -fx-padding: 10 20; -fx-alignment: center;" text="Rider Disponibili" textFill="white">
                    <font>
                        <Font name="System Bold" size="16" />
                    </font>
                </Label>

                <!-- Rider List -->
                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10;">
                        <VBox spacing="3">
                            <HBox alignment="CENTER_LEFT" spacing="5" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
    </center>

</BorderPane>
