<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-min-width: 900; -fx-min-height: 750;" styleClass="root-pane" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alessandro.caracciolo.catchit.view.controller.ManageOrdersGraphicController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-pane">
            <ImageView fitHeight="66.0" fitWidth="112.0" preserveRatio="true">
                <Image url="@../Logo.png" />
            </ImageView>
            <Label text="Manage orders" textFill="white">
                <font>
                    <Font name="System Bold" size="20" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="updateButton" onAction="#handleUpdateButton" styleClass="transparent-button" text="Update" />
         <Button fx:id="logoutButton" layoutX="818.0" layoutY="44.0" onAction="#handleLogoutButton" styleClass="transparent-button" text="Logout" />
        </HBox>
    </top>

    <center>
        <HBox prefHeight="369.0" prefWidth="591.0" spacing="20" styleClass="content-pane">
            <VBox prefHeight="597.0" prefWidth="859.0" spacing="15" styleClass="container-pane">
                <Label styleClass="blue-label" text="Orders" />
                <ScrollPane fitToWidth="true" prefHeight="500.0" prefWidth="612.0" styleClass="transparent-scroll">
                    <VBox fx:id="ordersContainer" prefHeight="0.0" prefWidth="513.0" spacing="15" styleClass="transparent-scroll" />
                </ScrollPane>
            <Button fx:id="showPendingOrdersButton" alignment="CENTER_RIGHT" onAction="#handleShowPendingOrdersButton" contentDisplay="RIGHT" layoutX="30.0" layoutY="30.0" styleClass="orange-button" text="Show Pending Orders" />
            </VBox>
        </HBox>
    </center>
</BorderPane>
