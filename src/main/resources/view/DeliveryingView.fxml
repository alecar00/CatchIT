<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import com.sothawo.mapjfx.MapView?>
<AnchorPane prefHeight="640.0" prefWidth="360.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alessandro.caracciolo.catchit.view.controller.DeliveryGraphicController">
   <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <MapView fx:id="mapView" VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER" prefHeight="70.0" prefWidth="360.0" style="-fx-background-color: #2a2a2a;">
               <children>
                  <Button fx:id="CallButton" mnemonicParsing="false" prefHeight="42.0" prefWidth="150.0" style="-fx-background-color: #2196f3; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand;" text="Call" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Button>

                  <Separator opacity="0.0" prefWidth="20.0" />

                  <Button fx:id="DeliveredButton" mnemonicParsing="false" prefHeight="42.0" prefWidth="150.0" style="-fx-background-color: #fe7430; -fx-background-radius: 25; -fx-padding: 10 20; -fx-cursor: hand;" text="Delivered" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Button>
               </children>
            </HBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
